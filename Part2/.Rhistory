##PART 2C
##For each year, fit a logistic regression model for the probability of diverted US flights
##using as many features as possible from attributesof the departure date,
##the scheduled departure and arrival times, the coordinates and distance
##between departure and planned arrival airports, and the carrier.
##Visualize the coefficients across years.
library(mlr3)
library(mlr3learners)
library(dplyr)
airports <- read.csv("airports.csv", header = TRUE)
dbWriteTable(conn, "airports", airports, overwrite = TRUE)
airports_db <- tbl(conn, "airports")
head(airports_db)
all_coefficients <- data.frame()
for(current_year in 2002:2006) {
print(paste("Processing Year:", current_year))
yearly_data <- ontime_db %>%
#remove cancelled flights
filter(Year == current_year & Cancelled == 0) %>%
#in flight_db airport = origin/dest and in airport_db - iata
inner_join(airports_db, by = c("Origin" = "iata")) %>%
#pulling origin data from flight_db to match w airport_db
rename(Origin_Lat = lat, Origin_Long = long) %>%
#pulling dest data from flight_db to match w airport_db
inner_join(airports_db, by = c("Dest" = "iata")) %>%
rename(Dest_Lat = lat, Dest_Long = long) %>%
select(Diverted, Month, DayOfWeek, CRSDepTime, CRSArrTime, Distance,
UniqueCarrier, Origin_Lat, Origin_Long, Dest_Lat, Dest_Long) %>%
#remove NA data
filter(!is.na(Diverted) & !is.na(Origin_Lat) & !is.na(Dest_Lat)) %>%
collect()
#taking 100k sample because 6million data will crash my laptop and r studio
#according to law of diminishing returns - taking 100k random samples is the same as calc from 6 million
#using statistics and 95% confidence level
#1% margin of error requires 9513 samples so 100k random samples is sufficient
yearly_data <- yearly_data %>%
mutate(
Diverted = as.factor(Diverted),
UniqueCarrier = as.factor(UniqueCarrier)
) %>%
sample_n(min(100000, nrow(.)))
#taskClassif = grouping into categories
task = TaskClassif$new(id = paste0("diverted_", current_year), backend = yearly_data, target = "Diverted")
#since we are doing LR - earger learner
learner = lrn("classif.log_reg", predict_type = "prob")
split = partition(task, ratio = 0.8) #splitting the data into 0.8:0.2 for train:test
learner$train(task, row_ids = split$train) #train model on training set only (0.8)
prediction = learner$predict(task, row_ids = split$test) #using test data to see if our predict train model was accurate
accuracy = prediction$score(msr("classif.acc"))
print(paste("Year", current_year, "Model Accuracy:", round(accuracy, 4)))
model_summary <- summary(learner$model)
coef_df <- as.data.frame(model_summary$coefficients)
coef_df$term <- rownames(coef_df)
coef_df$Year <- current_year
rownames(coef_df) <- NULL
coef_df <- coef_df %>%
select(term, Estimate, Year) %>%
filter(term != "(Intercept)")
#add to master dataframe
all_coefficients <- bind_rows(all_coefficients, coef_df)
}
print("MLR3 Modeling and Testing Complete!")
ggplot(all_coefficients, aes(x = Year, y = Estimate, color = term)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
facet_wrap(~ term, scales = "free_y") +
theme_minimal() +
labs(
title = "Logistic Regression Coefficients (2002-2006)",
subtitle = "Impact of Flight Features on the Probability of Diversion",
x = "Year",
y = "Coefficient Estimate (Log-Odds)"
) +
theme(
legend.position = "none", #using titles to explain it
axis.text.x = element_text(angle = 45, hjust = 1),
strip.text = element_text(size = 7, face = "bold")
)
##summary of 2c
#keeping only necessary data
summary_coefficients <- all_coefficients %>%
filter(!grepl("UniqueCarrier", term)) %>%
filter(!grepl("DayOfWeek", term)) %>%
filter(!grepl("Month", term))
ggplot(summary_coefficients, aes(x = Year, y = Estimate, color = term)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
facet_wrap(~ term, scales = "free_y") +
theme_minimal() +
labs(
title = "Key Drivers of Flight Diversions (2002-2006)",
subtitle = "Logistic Regression Coefficients (Core Flight Metrics)",
x = "Year",
y = "Coefficient Estimate (Log-Odds)"
) +
theme(
legend.position = "none",
axis.text.x = element_text(angle = 45, hjust = 1),
strip.text = element_text(size = 8, face = "bold")
)
knitr::opts_chunk$set(echo = TRUE)
#PART 1A
log_f <- function(x) {
return(log(0.5) - abs(x))
} #to ensure we always use log
N <- 10000
s <- 1
x0 <- 0
samples <- numeric(N + 1)
samples[1] <- x0
for (i in 1:N) {
x_prev <- samples[i]
x_star <- rnorm(1, mean = x_prev, sd = s) #rnorm = random normal
log_ratio <- log_f(x_star) - log_f(x_prev)
u <- runif(1, min=0, max=1)
if (log(u) < log_ratio) {
samples[i + 1] <- x_star  # Accept
} else {
samples[i + 1] <- x_prev  # Reject
}
}
final_samples <- samples[-1]
sample_mean <- mean(final_samples)
sample_sd <- sd(final_samples)
#cat = print & sprintf = show returns and round to 4df
cat(sprintf("Sample Mean: %.4f\n", sample_mean))
cat(sprintf("Sample Standard Deviation: %.4f\n", sample_sd))
hist(final_samples, freq = FALSE, breaks = 50,
col = "darkblue", border = "darkgray",
main = "Random Walk Metropolis (N=10000, s=1)",
xlab = "x", ylab = "Density",
xlim = c(-8, 8),
ylim = c(0, 0.6))
lines(density(final_samples), col = "blue", lwd = 2)
x_range <- seq(-10, 10, length.out = 500)
true_f <- 0.5 * exp(-abs(x_range))
lines(x_range, true_f, col = "red", lty = 2, lwd = 2)
legend("topright", legend = c("Kernel Density Estimate", "Truef(x)"),
col = c("blue", "red"), lty = c(1, 2), lwd = 2)
sample_mean <- mean(final_samples)
sample_sd <-sd(final_samples)
cat("Sample Mean:", sample_mean)
cat("Sample Standard Deviation:", sample_sd)
#PART 1B
#recall formula f(x) = 1/2exp
generate_chain <- function(N, s, x0) {
x <- numeric(N +1)
x[1] <- x0
for (i in 1:N) {
x_prev <- x[i]
x_star <- rnorm(1, mean = x_prev, sd = s)
log_ratio <- (log(0.5)- abs(x_star)) - (log(0.5) - abs(x_prev))
u <- runif(1, min = 0, max = 1)
if (log(u) < log_ratio) {
x[i + 1] <- x_star
} else {
x[i + 1] <- x_prev
}
}
return(x[-1])
}
#r estimate
calculate_R_est <- function(N, s, J, initial_values) {
chains <- matrix(nrow = N, ncol = J)
for (j in 1:J) {
chains[, j] <- generate_chain(N, s, initial_values[j])
}
M_j <- colMeans(chains)
V_j <- numeric(J)
for (j in 1:J) {
V_j[j] <- sum((chains[, j] - M_j[j])^2) / N
}
W <- mean(V_j)
M <- mean(M_j)
B <- sum((M_j - M)^2) / J
R_est <- sqrt((B + W) / W)
return(R_est)
}
N <- 2000
s_test <- 0.001
J <- 4
initial_values <- c(-2.0, -1.0, 1.0, 2.0)
R_est_value <- calculate_R_est(N, s_test, J, initial_values)
s_grid <- seq(0.001, 1.0, length.out = 50)
R_est_results <- numeric(length(s_grid))
for (i in 1:length(s_grid)) {
R_est_results[i] <- calculate_R_est(N, s_grid[i], J, initial_values)
}
plot(s_grid, R_est_results, type = "b", pch = 16, col = "purple",
xlab = "Step size (s)", ylab = "R-est Value",
main = sprintf("R-est Values across different step sizes (s)\n(N=%d, J=%d)", N, J))
abline(h = 1.05, col = "red", lty = 2, lwd = 2)
legend("topright", legend = "Convergence Threshold (1.05)",
col = "red", lty = 2, lwd = 2)
cat("R-est value for when s=0.001 is:", R_est_value)
results_table <- data.frame(StepSize = s_grid, REstimate = R_est_results)
print(results_table)
