position = position_dodge(width = 0.8),
vjust = -0.5,
size = 2.5) +
scale_y_continuous(labels = scales::percent_format()) +
scale_fill_manual(values = c("on_time" = "green",
"minor_delay" = "orange",
"moderate_delay" = "red",
"severe_delay" = "darkred")) +
