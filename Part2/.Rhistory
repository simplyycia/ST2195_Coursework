#group depature timing by morning, afternoon, night, redeye
time_of_day_summary <- delay_df %>%
filter(!is.na(delay_classification) & !is.na(Hour)) %>%
mutate(
Time_Of_Day = case_when(
Hour >= 0 & Hour <= 5 ~ "Red-eye",
Hour >= 5 & Hour <= 11 ~ "Morning",
Hour >= 12 & Hour <= 17 ~ "Afternoon",
Hour >= 18 & Hour <= 23 ~ "Night",
Hour == 24 ~ "Red-eye"
),
Time_Of_Day = factor(Time_Of_Day, levels = c("Red-eye", "Morning", "Afternoon", "Night"))
) %>%
group_by(Time_Of_Day, delay_classification) %>%
summarize(Count = n(), .groups="drop") %>%
group_by(Time_Of_Day) %>%
mutate(Percentage = Count/ sum(Count))
