##PART 2B
##Evaluate whether older planes suffer more delays on a year-to-year basis.
library(DBI)
library(dplyr)
library(ggplot2)
conn <- dbConnect(RSQLite::SQLite(), "airline_coursework.db")
planes <- read.csv("plane-data.csv", header = TRUE)
colSums(is.na(planes)) #checked for null values/data, returned 0
str(planes)
#both database has "year" and "Year" so im switching the one in planes to make it less complicated
names(planes)[names(planes) == "year"] <- "manufacture_year"
dbWriteTable(conn, "planes", planes, overwrite = TRUE)
planes
ontime_db <- tbl(conn, "ontime")
planes_db <- tbl(conn, "planes")
#overall summary of 5 years
q2b_data <- ontime_db %>%
#remove cancelled and diverted flights
filter(Cancelled == 0 & Diverted == 0) %>%
#join flight data to plane data
inner_join(planes_db, by = c("TailNum" = "tailnum")) %>%
filter(!is.na(manufacture_year) & manufacture_year != "" & manufacture_year != "None" & manufacture_year != "0000") %>%
mutate(plane_year = as.numeric(manufacture_year)) %>%
mutate(plane_age = Year - plane_year) %>%
filter(plane_age >= 0) %>% #remove any -ve years
group_by(plane_age) %>%
summarize(AvgDelay = mean(ArrDelay, na.rm = TRUE), .groups = "drop") %>%
collect()
print(q2b_data)
ggplot(q2b_data, aes(x = plane_age, y = AvgDelay)) +
geom_point(colour = "darkblue", size = 2) +
geom_smooth(method = "lm", color = "red", se= FALSE) + #best fit line
theme_minimal() +
labs(title = "Does Plane Age Affect Average Flight Delay?",
x = "Age of Plane (Years)",
y = "Average Arrival Delay (Minutes)")
#yearly summary
q2b_data_yearly <- ontime_db %>%
#remove cancelled and diverted flights
filter(Cancelled == 0 & Diverted == 0) %>%
#join flight data to plane data
inner_join(planes_db, by = c("TailNum" = "tailnum")) %>%
filter(!is.na(manufacture_year) & manufacture_year != "" & manufacture_year != "None" & manufacture_year != "0000") %>%
mutate(plane_year = as.numeric(manufacture_year)) %>%
mutate(plane_age = Year - plane_year) %>%
filter(plane_age >= 0) %>% #remove any -ve years
group_by(Year, plane_age) %>%
summarize(AvgDelay = mean(ArrDelay, na.rm = TRUE), .groups = "drop") %>%
collect()
print(q2b_data_yearly)
ggplot(q2b_data_yearly, aes(x = plane_age, y = AvgDelay)) +
geom_point(colour = "darkblue", size = 2) +
geom_smooth(method = "lm", color = "red", se= FALSE) + #best fit line
theme_minimal() +
labs(title = "Does Plane Age Affect Average Flight Delay?",
x = "Age of Plane (Years)",,ķ`
y = "Average Arrival Delay (Minutes)") +
facet_wrap(~ Year)
