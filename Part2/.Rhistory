filter(ActualElapsedTime >= 0 | is.na(ActualElapsedTime)) %>%
filter(CRSElapsedTime >= 0 | is.na(CRSElapsedTime)) %>%
#remove values greater than 2359
filter(DepTime <= 2359 | is.na(DepTime)) %>%
filter(ArrTime <= 2359 | is.na(ArrTime)) %>%
# /100 because its by 24hour clock: i.e. 1535 if we divide by 100 = 15.35
#floor = remove decimal so arrange by 1-23 hours
mutate(Hour = floor(CRSDepTime / 100)) %>%
group_by(Year, DayOfWeek, Hour) %>%
summarize(AvgDelay = mean(ArrDelay, na.rm = TRUE), .groups = "drop") %>%
collect()
q2a_data
#classifying and cleaning arrival delay data
delay_df <- ontime_db %>%
filter(Cancelled == 0 & Diverted == 0) %>%
mutate(Hour = floor(CRSDepTime / 100)) %>%
select(Year, Month, DayOfWeek, Hour, arrdelay = ArrDelay) %>%
collect()
delay_classification <- function(time) {
if (is.na(time)) {
return(NA) #if value is missing
} else if (time <= 15) {
return("on_time") #delay lesser than 15 mins
} else if (time < 60) {
return("minor_delay") #delay < 60 mins
} else if (time < 120) {
return("moderate_delay") #delay <120mins
} else {
return("severe_delay") #delay > 180 mins
}
}
delay_df$delay_classification <- sapply(delay_df$arrdelay, delay_classification)
print(head(delay_df))
q2a_days <- c("Monday","Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday")
q2a_months <- c("January", "February", "March", "April", "May","June","July","August", "September","October","November","December")
delay_df$dayofweekstring <- q2a_days[delay_df$DayOfWeek]
delay_df$monthstring <- q2a_months[delay_df$Month]
##assigning factor levels so it wont arrange alphabetically
delay_df$dayofweekstring <- factor(delay_df$dayofweekstring, levels = c("Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"))
delay_df$monthstring <- factor(delay_df$monthstring, levels = c("January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"))
delay_df$delay_classification <- factor(delay_df$delay_classification, levels = c("on_time", "minor_delay", "moderate_delay", "severe_delay"))
print(head(delay_df))
#best and worst months to fly
#calculating % of delay in each month
month_summary <- delay_df %>%
filter(!is.na(delay_classification) & !is.na(monthstring)) %>% #removing NA data
group_by(monthstring, delay_classification) %>%
summarize(Count = n(), .groups="drop") %>%
group_by(monthstring) %>%
mutate(Percentage = Count / sum(Count))
ggplot(month_summary, aes(x = monthstring, y = Percentage, fill = delay_classification)) +
geom_col(position = position_dodge(width=0.8), color = "blue", linewidth = 0.2) +
geom_text(aes(label = scales::percent(Percentage, accuracy = 1)),
position = position_dodge(width = 0.8),
vjust = -0.5,
size = 2.5) +
scale_y_continuous(labels = scales:: percent_format()) +
scale_fill_manual(values = c("on_time" = "green",
"minor_delay" = "orange",
"moderate_delay" = "red",
"severe_delay" = "darkred")) +
theme_minimal() +
labs(title = "Percentage of Flight Delays by Month" ,
x = "Month",
y = "Percentage of Flights",
fill = "Delay Severity")
